# Forțează LF pentru toate fișierele text — compatibil Linux/macOS/Windows
* text=auto eol=lf

# HTML, CSS, JS — explicit LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Fișiere binare — fără conversie
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
